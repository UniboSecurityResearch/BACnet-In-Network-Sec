#--------------------------------------------------------
# promptLine [-p prompt] [-d default]  #prompts for input line, with optional default, to stdout

promptLine() {
   local PROMPT DEFAULT ANSWER
   eval $(zargs -p=PROMPT -d=DEFAULT -- "$@")
   if [ -z "$PROMPT"  ] ; then PROMPT="Enter a line:"; fi
   if [ -n "$DEFAULT" ] ; then PROMPT="$PROMPT[$DEFAULT]"; fi
   read 1>&2 -p "$PROMPT" ANSWER;
   if [ -z "$ANSWER" ]; then ANSWER=$DEFAULT; fi
   echo -n "$ANSWER"
}

#--------------------------------------------------------
# zargs [match:flagname]... [match=parname]... -- commandline  #parses commandline for flags and params
#     returns a string for eval to consume to set vars and shift away matches
#     example: zargs  -f:MYFLAG --flag:MYFLAG -o=MYPAR -- -f -o optval more stuff
#     returns stdout: 'local MYFLAG=true;shift;local MYPAR="optval";shift;shift;'
#     limitation: does not do compressed flags, i.e., "ls -al" would need to be "ls -a -l"
#     limitation: all options must precede the rest of the arguments

zargs() { 
   local SPECIFIERS=() RESULT="" SPEC MATCH NAME 
   # consume all the option specifiers before the first '--'
   while [ -n "$1" -a "$1" != "--" ] ; do SPECIFIERS+=("$1"); shift;  done
   shift; # toss '--'
   # now parse commandline portion, comparing each to the specifiers
   while [ "$1" ] ; do   
      for SPEC in "${SPECIFIERS[@]}"; do
         if [[ "$SPEC" = *":"* ]]; then  # if spec has a ':' then it's a flag
            MATCH="${SPEC%%:*}" NAME="${SPEC#*:}"
            if [ "$1" == "$MATCH" ]; then    
               RESULT="$RESULT""local $NAME='$1';shift;"; break;
            fi
        else                             #else it's a parameter 
            MATCH="${SPEC%%=*}" NAME="${SPEC#*=}"
            if [ "$1" == "$MATCH" ]; then
                RESULT="$RESULT local $NAME='${2//\"/\\\"}';shift;shift;"; shift; break;
            fi
        fi
      done
      shift;
   done
   echo -n "$RESULT"
}

#--------------------------------------------------------
# fileExtension PATH             # returns /foo/bar.txt as txt

fileExtension() {
   local g=$(fileFileName "$1")
   if [[ $g = *.* ]]; then
      echo ${g##*.}
   else
      echo ''
   fi
}

############################################################################
# This is the magic dispatcher. It's the only part of the script that's NOT in a function.
# This has to be at the END of the script file.
# It calls the function named by the first arg and passes that function all the 
# remaining args as its $1 $2, etc.
#     e.g., $ cert blah arg1 arg2 
# will call function blah() above with $1=arg1 $2=arg2
# If first arg is "x", then it will turn on debug mode before calling the function
#     e.g., $ cert x blah arg1 arg2 
# If you call this without any arguments, it will list all the functions and their usages

if [[ ! $1 ]]; then cat "$0" | grep \#\: ;  exit; fi
if [[ $1 == "x" ]]; then set -x; shift; fi
COMMAND="$1"; shift; $COMMAND "$@"


