#: hex2bin    # converts hex from stdin to binary in stdout

hex2bin() {
    xxd -r -p 
}

#----------------------------------------------------
#: bin2hex    # converts binary from stdin to hex in stdout

bin2hex() {
    xxd -p | tr -d '\n'
}


